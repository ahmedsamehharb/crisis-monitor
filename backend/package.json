{
  "name": "crisis-monitor-backend",
  "version": "1.0.0",
  "description": "Crisis monitoring backend for Baden-Württemberg VOST automation",
  "type": "module",
  "main": "dist/app/server.js",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "start": "tsx src/app/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "echo \"Add tests in tests/\" && exit 0"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
