PORT=3001
NODE_ENV=development

# Optional — omit for in-memory-only mode during hackathon
# DATABASE_URL=postgresql://crisis:crisis@localhost:5432/crisis_monitor

INGESTION_ENABLED=true

MASTODON_ENABLED=false
MASTODON_INSTANCE=mastodon.social
MASTODON_STREAM=public
MASTODON_ACCESS_TOKEN=
MASTODON_MODE=search
MASTODON_POLL_LOCAL=false
MASTODON_POLL_INTERVAL_MS=15000

BLUESKY_ENABLED=false
BLUESKY_API_BASE=https://api.bsky.app
BLUESKY_POLL_INTERVAL_MS=15000

DWD_ENABLED=true
DWD_POLL_INTERVAL_MS=600000
DWD_BW_ONLY=true
DWD_SOURCE=auto
DWD_JSON_URL=https://www.dwd.de/DWD/warnungen/warnapp/json/warnings.json
DWD_CAP_DIFF_URL=https://opendata.dwd.de/weather/alerts/cap/DISTRICT_EVENT_DIFF/

PEGELONLINE_ENABLED=true
PEGELONLINE_API_BASE=https://www.pegelonline.wsv.de/webservices/rest-api/v2
PEGELONLINE_POLL_INTERVAL_MS=300000
PEGELONLINE_WATERS=NECKAR,RHEIN,DONAU,MAIN,KOCHER,ENZ,MURG,KINZIG,ILLER,TAUBER
PEGELONLINE_WARNING_RATIO=0.9
