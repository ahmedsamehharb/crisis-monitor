# Backend — Kopieren nach backend/.env

PORT=3001

# Pitch/Demo: Bluesky + Mastodon alle 5s statt 15s pollen
DEMO_MODE=true

# Bluesky (kein Token nötig)
BLUESKY_ENABLED=true
# BLUESKY_POLL_INTERVAL_MS=5000

# Mastodon (Token von mastodon.social → Einstellungen → Entwicklung)
MASTODON_ENABLED=true
MASTODON_ACCESS_TOKEN=
# MASTODON_POLL_INTERVAL_MS=5000

# Optional: Postgres (ohne DATABASE_URL läuft In-Memory)
# DATABASE_URL=postgresql://...
