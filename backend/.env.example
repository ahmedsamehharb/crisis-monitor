PORT=3001
NODE_ENV=development

# Optional — omit for in-memory-only mode during hackathon
# DATABASE_URL=postgresql://crisis:crisis@localhost:5432/crisis_monitor

INGESTION_ENABLED=true

MASTODON_ENABLED=false
MASTODON_INSTANCE=mastodon.social
MASTODON_STREAM=public
MASTODON_ACCESS_TOKEN=
MASTODON_MODE=search
MASTODON_POLL_LOCAL=false
MASTODON_POLL_INTERVAL_MS=15000

BLUESKY_ENABLED=false
BLUESKY_API_BASE=https://api.bsky.app
BLUESKY_POLL_INTERVAL_MS=15000

DWD_ENABLED=true
DWD_POLL_INTERVAL_MS=600000
DWD_BW_ONLY=true
DWD_SOURCE=auto
DWD_JSON_URL=https://www.dwd.de/DWD/warnungen/warnapp/json/warnings.json
DWD_CAP_DIFF_URL=https://opendata.dwd.de/weather/alerts/cap/DISTRICT_EVENT_DIFF/

PEGELONLINE_ENABLED=true
PEGELONLINE_API_BASE=https://www.pegelonline.wsv.de/webservices/rest-api/v2
PEGELONLINE_POLL_INTERVAL_MS=300000
PEGELONLINE_WATERS=NECKAR,RHEIN,DONAU,MAIN,KOCHER,ENZ,MURG,KINZIG,ILLER,TAUBER
PEGELONLINE_WARNING_RATIO=0.9

# NASA FIRMS wildfire hotspots (register free MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/map_key/)
# Rate limit: 5,000 API transactions per 10-minute interval (default poll = 1 txn / 10 min)
FIRMS_ENABLED=true
FIRMS_MAP_KEY=
FIRMS_API_BASE=https://firms.modaps.eosdis.nasa.gov/api
FIRMS_SOURCE=VIIRS_NOAA20_NRT
FIRMS_DAY_RANGE=1
FIRMS_POLL_INTERVAL_MS=600000
FIRMS_BBOX_WEST=7.5
FIRMS_BBOX_SOUTH=47.4
FIRMS_BBOX_EAST=10.6
FIRMS_BBOX_NORTH=49.8

# Geocoding — LLM location extraction + Nominatim (put API key in .env only, never commit)
GEOCODING_ENABLED=true
GEOCODING_LLM_BASE_URL=https://litellm-kommone.genai.govdigital.de/v1
GEOCODING_LLM_API_KEY=
GEOCODING_LLM_MODEL=stackit-qwen-qwen3-vl-235b-a22b-instruct-fp8
GEOCODING_MIN_CONFIDENCE=0.6
GEOCODING_SOCIAL_ONLY=true
GEOCODING_BW_ONLY=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
